{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sparky-game-history",
  "main": "src/index.js",
  "compatibility_date": "2026-07-20",
  "workers_dev": true,
  "vars": {
    "DISCORD_ID": "692126247458832455"
  },
  "kv_namespaces": [
    {
      "binding": "GAME_HISTORY",
      "id": "5fb6b1e577ac4f5b821aae183bf4e7ac"
    }
  ],
  "triggers": {
    "crons": ["* * * * *"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  }
}
